classDiagram
    class Owner {
        +String name
        +String address
        +String phone
    }

    class Pet {
        +String name
        +String breed
        +Int age
        +List~String~ medications
        +addPet()
        +removePet()
        +updatePetInfo()
    }

    class Schedule {
        +List~Task~ tasks
        +addTask(task: Task)
    }

    class Task {
        +String type
        +String name
        +String priority
        +String time
        +createTask()
        +updateTask()
    }

    Owner "1" --> "0..*" Pet : owns
    Owner "1" --> "1" Schedule : manages
    Schedule "1" --> "0..*" Task : contains
    Schedule "1" --> "0..*" Pet : tracks
